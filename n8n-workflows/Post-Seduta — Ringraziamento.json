    {
      "parameters": {
        "jsCode": "const responseData = $input.first().json;\nconst appointments = Array.isArray(responseData) ? responseData : [];\nif (appointments.length === 0) return [];\n\nreturn appointments.map(function(appt) {\n  var client = appt.clients || {};\n  if (!client.email) return null;\n  return { json: {\n    clientId:  client.id,\n    emailTo:   client.email,\n    phoneTo:   client.phone || '',\n    nameTo:    ((client.first_name||'') + ' ' + (client.last_name||'')).trim(),\n    nome:      client.first_name || 'cliente',\n    dashboardLink: 'https://www.irenegipsytattoo.com/dashboard.html'\n  }};\n}).filter(Boolean);"
      },
