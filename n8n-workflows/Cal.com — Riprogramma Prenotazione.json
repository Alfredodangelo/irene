    {
      "parameters": {
        "jsCode": "// Dati dal webhook\nconst d = $('Estrai Dati').item.json;\nconst appointment_id  = d.appointment_id;\nconst new_start_iso   = d.new_start_iso;\nconst fallback_email  = d.client_email || '';\n\n// Dati da Supabase\nconst rows = Array.isArray($input.item.json) ? $input.item.json : [$input.item.json];\nconst appt   = rows[0] || {};\nconst client = (appt.clients && typeof appt.clients === 'object') ? appt.clients : {};\n\n// UID da cancellare: prima quello passato dal webhook, poi quello in Supabase\nconst uid_for_cancel = d.cal_booking_uid || appt.cal_booking_uid || 'not-found';\n\n// Mappa tipo → eventTypeId ADMIN (orari illimitati)\nconst EVENT_TYPE_IDS = { consulenza: 5147645, 'pre-seduta': 5147653, seduta: 5147823 };\nconst eventTypeId = EVENT_TYPE_IDS[appt.type] || 5147645;\n\nconst clientName  = [client.first_name, client.last_name].filter(Boolean).join(' ').trim() || client.email || fallback_email;\nconst clientEmail = client.email || fallback_email;\nconst clientPhone = client.phone || '';\n\n// v2: attendee object (non responses)\nconst attendee = {\n  name:     clientName,\n  email:    clientEmail,\n  timeZone: 'Europe/Rome',\n  language: 'it'\n};\nif (clientPhone) attendee.phoneNumber = clientPhone;\n\nconst calPayload = {\n  eventTypeId,\n  start: new_start_iso,\n  attendee,\n  metadata: {\n    pagamento:        appt.payment_method || '',\n    descrizione_idea: appt.notes || ''\n  }\n};\nif (appt.notes) calPayload.bookingFieldsResponses = { notes: appt.notes };\n\nreturn [{ json: {\n  uid_for_cancel,\n  calBodyString: JSON.stringify(calPayload),\n  appointment_id,\n  new_start_iso,\n  client_email: clientEmail\n} }];"
      },
