    {
      "parameters": {
        "jsCode": "const rows = Array.isArray($input.item.json) ? $input.item.json : [];\nif (rows.length === 0) return [];\nreturn rows.map(offer => {\n  const client = offer.clients || {};\n  const clientName  = [client.first_name, client.last_name].filter(Boolean).join(' ') || 'Cliente';\n  const clientEmail = client.email || '';\n  const dt = new Date(offer.freed_slot_at);\n  const dateFormatted = dt.toLocaleDateString('it-IT', { weekday:'long', day:'2-digit', month:'long', year:'numeric' });\n  return { json: { offer_id: offer.id, client_id: offer.client_id, clientName, clientEmail, dateFormatted, freed_slot_at: offer.freed_slot_at } };\n});"
      },
