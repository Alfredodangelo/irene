        "jsCode": "const b = $input.item.json.body || $input.item.json;\nconst appointment_id   = b.appointment_id   || '';\nconst cal_booking_uid  = b.cal_booking_uid  || null;\nconst client_email     = b.client_email     || '';\nconst client_name      = b.client_name      || 'Cliente';\nconst scheduled_at     = b.scheduled_at     || null;\nconst appointment_type = b.appointment_type || 'consulenza';\n\nif (!appointment_id) throw new Error('appointment_id mancante');\nif (!client_email)   throw new Error('client_email mancante');\n\nreturn [{ json: { appointment_id, cal_booking_uid, client_email, client_name, scheduled_at, appointment_type } }];"
