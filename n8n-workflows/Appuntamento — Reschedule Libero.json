    {
      "parameters": {
        "jsCode": "const d = $('Estrai Dati').item.json;\nconst rows = Array.isArray($input.item.json) ? $input.item.json : [$input.item.json];\nconst appt   = rows[0] || {};\nconst client = (appt.clients && typeof appt.clients === 'object') ? appt.clients : {};\nconst uid_for_cancel = d.old_cal_booking_uid || appt.cal_booking_uid || null;\n// Event type admin per tipo appuntamento\nconst typeEventIds = { seduta: 5147823, 'pre-seduta': 5147653, consulenza: 5147645 };\nconst appt_type = appt.type || 'seduta';\nconst eventTypeId = typeEventIds[appt_type] || 5147823;\nconst clientName  = d.client_name  || [client.first_name, client.last_name].filter(Boolean).join(' ') || 'Cliente';\nconst clientEmail = d.client_email || client.email || '';\nconst clientPhone = client.phone   || '';\nreturn [{ json: {\n  uid_for_cancel,\n  eventTypeId,\n  appt_type,\n  appt_notes: appt.notes || null,\n  appointment_id: d.appointment_id,\n  new_start_iso:  d.new_start_iso,\n  client_email:   clientEmail,\n  client_name:    clientName,\n  client_phone:   clientPhone,\n  client_id:      d.client_id,\n  freed_slot_at:  d.freed_slot_at\n} }];"
      },
