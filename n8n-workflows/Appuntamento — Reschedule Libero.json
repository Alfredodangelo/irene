        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const d = $('Salva Nuovo UID').item.json; const isSeduta = d.appt_type === 'seduta'; const labels = { seduta: 'seduta', 'pre-seduta': 'pre-seduta', consulenza: 'consulenza' }; const label = labels[d.appt_type] || 'seduta'; const titleLabel = { seduta: 'Seduta', 'pre-seduta': 'Pre-seduta', consulenza: 'Consulenza' }[d.appt_type] || 'Appuntamento'; const notifType = isSeduta ? 'seduta_free_reschedule' : 'appointment_rescheduled'; const title = titleLabel + ' spostata dal cliente'; const body = d.client_name + ' ha spostato la ' + label + ' al ' + new Date(d.new_start_iso).toLocaleString('it-IT', { weekday:'long', day:'2-digit', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit', timeZone:'Europe/Rome' }) + (isSeduta && d.freed_slot_at ? '. Posto liberato: ' + new Date(d.freed_slot_at).toLocaleString('it-IT', { weekday:'long', day:'2-digit', month:'long', timeZone:'Europe/Rome' }) : ''); const meta = (isSeduta && d.freed_slot_at) ? { freed_slot_at: d.freed_slot_at, client_name: d.client_name } : null; return JSON.stringify({ type: notifType, title, body, client_id: d.client_id, read: false, meta }); })() }}",
        "options": {}
