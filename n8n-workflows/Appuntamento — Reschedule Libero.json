    {
      "parameters": {
        "jsCode": "const calResp = $input.item.json;\nconst d = $('Prepara Dati Cal').item.json;\n// Leggi bookingFieldsResponses dal booking originale\nconst originalFields = calResp.data?.bookingFieldsResponses || calResp.bookingFieldsResponses || {};\n// Costruisci attendee\nconst attendee = { name: d.client_name, email: d.client_email, timeZone: 'Europe/Rome', language: 'it' };\nif (d.client_phone) attendee.phoneNumber = d.client_phone;\n// Costruisci payload finale mantenendo i campi originali (incluso numeroseduta, ecc.)\nconst calBody = {\n  eventTypeId: d.eventTypeId,\n  start: d.new_start_iso,\n  attendee,\n  bookingFieldsResponses: { ...originalFields }\n};\n// Aggiorna note interne se presenti in Supabase\nif (d.appt_notes) calBody.bookingFieldsResponses.notes = d.appt_notes;\nreturn [{ json: {\n  calBody,\n  uid_for_cancel:  d.uid_for_cancel,\n  appointment_id:  d.appointment_id,\n  new_start_iso:   d.new_start_iso,\n  client_email:    d.client_email,\n  client_name:     d.client_name,\n  client_id:       d.client_id,\n  freed_slot_at:   d.freed_slot_at,\n  appt_type:       d.appt_type\n} }];"
      },
