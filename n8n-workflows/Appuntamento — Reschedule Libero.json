        "jsonBody": "={{ JSON.stringify({ type: 'reschedule_error', title: '❌ Errore cambio data', body: $('Salva Nuovo UID').item.json.client_name + ' ha provato a cambiare data ma Cal.com non ha creato il nuovo booking. Il vecchio booking è stato cancellato. Intervieni manualmente.', client_id: $('Salva Nuovo UID').item.json.client_id, read: false, meta: { appointment_id: $('Salva Nuovo UID').item.json.appointment_id, new_start_iso: $('Salva Nuovo UID').item.json.new_start_iso } }) }}",
