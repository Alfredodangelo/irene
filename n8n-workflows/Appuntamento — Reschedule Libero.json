    {
      "parameters": {
        "jsCode": "const b = $input.item.json.body || $input.item.json;\nconst appointment_id        = b.appointment_id        || '';\nconst new_start_iso         = b.new_start_iso         || '';\nconst client_id             = b.client_id             || '';\nconst client_email          = b.client_email          || '';\nconst client_name           = b.client_name           || 'Cliente';\nconst old_cal_booking_uid   = b.old_cal_booking_uid   || null;\nconst freed_slot_at         = b.freed_slot_at         || null;\nif (!appointment_id) throw new Error('appointment_id mancante');\nif (!new_start_iso)  throw new Error('new_start_iso mancante');\nreturn [{ json: { appointment_id, new_start_iso, client_id, client_email, client_name, old_cal_booking_uid, freed_slot_at } }];"
      },
