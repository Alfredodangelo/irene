        "jsCode": "// Estrae i dati dal body del POST e formatta la data\nconst b = $input.item.json.body || $input.item.json;\n\nconst client_email = b.client_email || '';\nconst client_name  = b.client_name  || 'Cliente';\nconst esito        = b.esito        || 'accepted';\nconst new_date     = b.new_date     || '';\nconst new_time     = b.new_time     || '';\nconst irene_notes  = b.irene_notes  || '';\n\n// Formatta la data in italiano (es. \"mercoledì 15 aprile 2026\")\nlet data_formatted = new_date;\ntry {\n  const d = new Date(new_date + 'T00:00:00');\n  data_formatted = d.toLocaleDateString('it-IT', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });\n} catch(e) {}\n\n// Blocco HTML note Irene (usato solo nel ramo rifiuto)\nconst notes_html = irene_notes\n  ? `<div style=\"background:#fff7ed;border-left:4px solid #f97316;border-radius:4px;padding:14px 18px;margin:20px 0;font-size:0.92rem;\"><strong>Note di Irene:</strong><br>${irene_notes}</div>`\n  : '';\n\nreturn [{ json: { client_email, client_name, esito, new_date, new_time, irene_notes, data_formatted, notes_html } }];"
      },
