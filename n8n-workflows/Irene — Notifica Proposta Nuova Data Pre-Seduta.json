      "parameters": {
        "jsCode": "const b = $input.item.json.body || $input.item.json;\nconst client_email  = b.client_email  || '';\nconst client_name   = b.client_name   || 'Cliente';\nconst proposed_date = b.proposed_date || '';\nconst proposed_time = b.proposed_time || '';\nconst reason        = b.reason        || '';\n\nif (!client_email)  throw new Error('client_email mancante');\nif (!proposed_date) throw new Error('proposed_date mancante');\n\n// Formatta la data in italiano\nconst dt = new Date(proposed_date + 'T12:00:00');\nconst dateFormatted = dt.toLocaleDateString('it-IT', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });\n\nreturn [{ json: { client_email, client_name, proposed_date, proposed_time, reason, dateFormatted } }];"
      },
